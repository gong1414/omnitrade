# ===========================================
# AI 加密货币自动交易系统 - 环境变量配置
# ===========================================

# ============================================
# 服务器配置
# ============================================
# Web 服务器监听端口
PORT=3100

# ============================================
# 交易配置
# ============================================
# 交易循环间隔（分钟）
# 建议：波段趋势策略使用20分钟，超短线策略使用5分钟
TRADING_INTERVAL_MINUTES=20

# 是否启用 APScheduler 驱动的自动交易循环（Phase 8.7）
# true: 启动时根据 TRADING_INTERVAL_MINUTES 自动周期性运行 monitor.tick()
# false (默认，安全): 仅 REST API 启动，不自动触发交易循环
SCHEDULER_ENABLED=false

# 每轮交易观察的交易对列表（逗号分隔）
TRADING_SYMBOLS=["BTC_USDT","ETH_USDT"]

# 每 UTC 日绝对 USDT 亏损上限（PR-D Phase D3 account-level kill-switch）
# 一旦今日 realized PnL 跌破 -DAILY_LOSS_CAP_USDT，下一轮 open/close/partial_close 决策
# 被 risk-check 层强制改写为 hold。hold 决策不受影响。
DAILY_LOSS_CAP_USDT=100.0

# 最大杠杆倍数
MAX_LEVERAGE=25
MAX_POSITIONS=5
MAX_HOLDING_HOURS=36
EXTREME_STOP_LOSS_PERCENT=-30

# 交易策略（arena-scalper, arena-swingsmith, arena-guardian, arena-steward, arena-raider, arena-raider-squad, arena-rebate-hunter, arena-autopilot, arena-tribunal）
# arena-scalper:            超短线策略（5分钟周期，快进快出，中高风险）
# arena-swingsmith:            波段趋势策略（20分钟周期，捕捉中期趋势，中低风险） 波段的平仓止盈由代码控制，其他的策略由AI控制
# arena-guardian:           稳健策略（低风险低杠杆，保护本金优先）
# arena-steward:               平衡策略（风险收益平衡，默认策略）
# arena-raider:             激进策略（高风险高杠杆，追求高收益）
# arena-raider-squad:        激进团策略（团长+双团员突击决策，高杠杆高仓位，激进出击不畏缩，⚠️ 注意：多Agent协作会消耗更多token）
# arena-rebate-hunter:         返佣套利策略（5分钟周期，高频微利交易，适合有手续费返佣的用户，代码级止损止盈）
# arena-autopilot:          AI自主策略（完全由AI主导，不提供任何策略建议，AI自主分析和决策）
# arena-tribunal:  陪审团策略（法官+陪审团合议决策，1主Agent+3专业Agent，高质量决策，⚠️ 注意：多Agent协作会消耗更多token）
#
# 推荐配置组合：
# 1. 波段趋势（中长线）        ：TRADING_STRATEGY=arena-swingsmith, TRADING_INTERVAL_MINUTES=20
# 2. 超短线（快进快出）        ：TRADING_STRATEGY=arena-scalper, TRADING_INTERVAL_MINUTES=5
# 3. 稳健均衡                  ：TRADING_STRATEGY=arena-steward, TRADING_INTERVAL_MINUTES=10
# 4. 激进团（团队突击）        ：TRADING_STRATEGY=arena-raider-squad, TRADING_INTERVAL_MINUTES=5
# 5. 返佣套利（高频微利）      ：TRADING_STRATEGY=arena-rebate-hunter, TRADING_INTERVAL_MINUTES=5
# 6. AI自主（完全自主决策，默认）：TRADING_STRATEGY=arena-autopilot, TRADING_INTERVAL_MINUTES=5
# 7. 陪审团（多Agent合议，高成本）：TRADING_STRATEGY=arena-tribunal, TRADING_INTERVAL_MINUTES=5
TRADING_STRATEGY=arena-autopilot

# 初始资金（USDT）
INITIAL_BALANCE=1000
ACCOUNT_STOP_LOSS_USDT=50          # 止损线
ACCOUNT_TAKE_PROFIT_USDT=20000      # 止盈线
SYNC_CONFIG_ON_STARTUP=true        # 启动时同步配置

# ============================================
# 数据库配置
# ============================================
# 数据库连接 URL
# 使用本地 SQLite: file:././data/trading.db
# 使用远程 Turso: libsql://your-database.turso.io
DATABASE_URL=file:././data/trading.db

# ============================================
# 交易所配置
# ============================================
# 选择使用的交易所（gate/okx，默认: gate）
EXCHANGE=gate

# ============================================
# Gate.io API 配置
# ============================================
# Gate.io API 密钥（必需）
GATE_API_KEY=your_api_key_here

# Gate.io API 密钥（必需）
GATE_API_SECRET=your_api_secret_here

# 是否使用 Gate.io 测试网（true/false）
GATE_USE_TESTNET=true

# OKX API 配置
# ============================================
# OKX API 密钥（必需，当 EXCHANGE=okx 时）
OKX_API_KEY=your_okx_api_key_here

# OKX API 密钥（必需，当 EXCHANGE=okx 时）
OKX_API_SECRET=your_okx_api_secret_here

# OKX API 口令（必需，当 EXCHANGE=okx 时）
OKX_API_PASSPHRASE=your_okx_passphrase_here

# 是否使用 OKX 测试网（true/false）
# 测试网和正式网使用相同域名，通过 x-simulated-trading header 区分
OKX_USE_TESTNET=true

# ============================================
# 手动平仓密码配置
# ============================================
# 用于网页界面手动平仓功能的密码验证（必需）
# 如果不设置此密码，网页平仓功能将被禁用
# 建议：设置一个强密码，不要使用 API 密钥
CLOSE_POSITION_PASSWORD=

# ============================================
# AI 模型配置
# ============================================
# OpenAI 兼容的 API 密钥（必需）
# 支持 OpenAI、OpenRouter 或其他兼容供应商
OPENAI_API_KEY=your_api_key_here

# OpenAI 兼容的 API 基础地址（可选）
# OpenRouter: https://openrouter.ai/api/v1
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# 或其他兼容 OpenAI API 的供应商地址
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# AI 模型名称（可选，默认使用 deepseek/deepseek-v3.2-exp）
# 注意：不同供应商的模型名称不同
# OpenRouter: deepseek/deepseek-v3.2-exp, x-ai/grok-4-fast, 等
# OpenAI: gpt-4, gpt-3.5-turbo, 等
# DeepSeek: deepseek-chat, deepseek-coder, 等
AI_MODEL_NAME=deepseek/deepseek-v3.2-exp
#AI_MODEL_NAME=x-ai/grok-4-fast

# ============================================
# Gate MCP News 配置（消息面数据）
# ============================================
# 是否启用 Gate News MCP（默认启用，设置为 false 可关闭）
# GATE_NEWS_MCP_ENABLED=true
# Gate News MCP 端点地址（默认: https://api.gatemcp.ai/mcp/news）
# GATE_NEWS_MCP_URL=https://api.gatemcp.ai/mcp/news

# ============================================
# 账户回撤风控配置
# ============================================
# 当账户资产相比峰值回撤达到以下百分比时的风控措施：
ACCOUNT_DRAWDOWN_WARNING_PERCENT=20          # 警告阈值：发出风险警告提醒
ACCOUNT_DRAWDOWN_NO_NEW_POSITION_PERCENT=30  # 禁止开仓阈值：停止开新仓位，只允许平仓
ACCOUNT_DRAWDOWN_FORCE_CLOSE_PERCENT=50      # 强制平仓阈值：自动平掉所有仓位，保护剩余资金

# ============================================
# 返佣配置
# ============================================
# 手续费返佣比例（百分比，默认20%）
# 例如：20 表示返还手续费的20%
FEE_REBATE_PERCENT=20

# ============================================
# 账户记录配置
# ============================================
# 账户资产记录间隔（分钟）
# 说明：定期记录账户资产到数据库，生成资产曲线
# 注意：系统还会在账户净值创新高时实时记录（10秒检查周期），确保峰值不丢失
ACCOUNT_RECORD_INTERVAL_MINUTES=1

# ============================================
# 外部数据源配置
# ============================================
# 每个数据源可独立开关（默认全部启用，设置为 false 可关闭）
# 免费数据源（无需 API Key）
DATASOURCE_CRYPTO_NEWS_ENABLED=true        # free-crypto-news: 200+源新闻聚合 + AI情绪分析
DATASOURCE_FEAR_GREED_ENABLED=true         # Alternative.me: 恐惧贪婪指数
DATASOURCE_COINGECKO_ENABLED=true          # CoinGecko: 全市场数据、BTC主导率
DATASOURCE_ONCHAIN_ENABLED=true            # 链上数据: BTC算力/内存池, ETH Gas
DATASOURCE_ORDER_BOOK_ENABLED=true         # 订单簿深度: 买卖盘不平衡度
DATASOURCE_OPEN_INTEREST_ENABLED=true      # 未平仓量(OI): 通过交易所API获取

# 需要 API Key 的数据源（无 Key 时自动禁用）
DATASOURCE_COINGLASS_ENABLED=true          # Coinglass: 多空比、爆仓数据、全网OI
COINGLASS_API_KEY=                         # 申请: https://www.coinglass.com/pricing

DATASOURCE_WHALE_ALERT_ENABLED=true        # Whale Alert: 大额链上转账监控
WHALE_ALERT_API_KEY=                       # 申请: https://whale-alert.io/

# Etherscan API Key（可选，提高链上数据请求频率）
ETHERSCAN_API_KEY=                         # 申请: https://etherscan.io/apis

DATASOURCE_LUNAR_CRUSH_ENABLED=true        # LunarCrush: Twitter/社交媒体情绪量化
LUNAR_CRUSH_API_KEY=                       # 申请: https://lunarcrush.com/developers

# ============================================
# OpenSpace 自进化技能引擎配置
# ============================================
# 是否启用 OpenSpace 自进化决策（true/false）
OPENSPACE_ENABLED=true
# OpenSpace MCP Server 地址（Docker 内网络）
OPENSPACE_MCP_URL=http://openspace:8080
# OpenSpace Dashboard 端口
OPENSPACE_DASHBOARD_PORT=7788
# 是否启用社区技能共享
OPENSPACE_CLOUD_ENABLED=true
# llmtrading MCP Server 端口（供 OpenSpace 回调）
TRADING_MCP_PORT=9090
