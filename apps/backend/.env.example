# ===========================================
# OmniTrade Backend — Environment Variables
# ===========================================
# Copy to .env and fill in real values before running.
# Phase-0 findings resolutions (user-approved):
#   TRADING_STRATEGY=arena-autopilot  (follows .env.example, not registry fallback arena-dual-signal)
#   ACCOUNT_RECORD_INTERVAL_MINUTES=1  (follows .env.example, not code default 10)

# ── Server ─────────────────────────────────────────────────────────────────
PLATFORM_PORT=8000

# ── Trading ────────────────────────────────────────────────────────────────
TRADING_STRATEGY=arena-autopilot
TRADING_INTERVAL_MINUTES=20
MAX_LEVERAGE=25
MAX_POSITIONS=5
MAX_HOLDING_HOURS=36
EXTREME_STOP_LOSS_PERCENT=-30
INITIAL_BALANCE_USDT=1000
ACCOUNT_STOP_LOSS_USDT=50
ACCOUNT_TAKE_PROFIT_USDT=20000
SYNC_CONFIG_ON_STARTUP=true

# Drawdown risk controls
ACCOUNT_DRAWDOWN_WARNING_PERCENT=20
ACCOUNT_DRAWDOWN_NO_NEW_POSITION_PERCENT=30
ACCOUNT_DRAWDOWN_FORCE_CLOSE_PERCENT=50

# Account recorder interval (Phase-0 finding #3: env.example wins over code default of 10)
ACCOUNT_RECORD_INTERVAL_MINUTES=1

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/omnitrade.db

# ── Exchange ───────────────────────────────────────────────────────────────
EXCHANGE=gate

# Gate.io
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret
GATE_USE_TESTNET=true

# OKX (used when EXCHANGE=okx)
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_passphrase
OKX_USE_TESTNET=true

# Manual close password (empty = disable UI close)
MANUAL_CLOSE_PASSWORD=

# ── LLM (via LiteLLM) ──────────────────────────────────────────────────────
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_or_openrouter_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek/deepseek-chat
DEEPSEEK_API_KEY=

# Reject LLM responses without tool_calls. Set false for 1-release rollback only.
STRICT_TOOL_CALLS=true

# ── External data sources ──────────────────────────────────────────────────
DATASOURCE_CRYPTO_NEWS_ENABLED=true
DATASOURCE_FEAR_GREED_ENABLED=true
DATASOURCE_COINGECKO_ENABLED=true
DATASOURCE_ONCHAIN_ENABLED=true
DATASOURCE_ORDER_BOOK_ENABLED=true
DATASOURCE_OPEN_INTEREST_ENABLED=true
DATASOURCE_COINGLASS_ENABLED=true
COINGLASS_API_KEY=
DATASOURCE_WHALE_ALERT_ENABLED=true
WHALE_ALERT_API_KEY=
ETHERSCAN_API_KEY=
DATASOURCE_LUNAR_CRUSH_ENABLED=true
LUNAR_CRUSH_API_KEY=

# ── MCP servers ────────────────────────────────────────────────────────────
GATE_NEWS_MCP_ENABLED=true
GATE_NEWS_MCP_URL=https://api.gatemcp.ai/mcp/news
OPENSPACE_ENABLED=true
OPENSPACE_MCP_URL=http://openspace:8080
OPENSPACE_CLOUD_ENABLED=true
TRADING_MCP_PORT=9090
OPENSPACE_DASHBOARD_PORT=7788

# ── Rebate ─────────────────────────────────────────────────────────────────
FEE_REBATE_PERCENT=20

# ── Multi-agent orchestrator (Phase 8.5a) ──────────────────────────────────
# Rollback kill-switch. When false (default) the single-agent path is active
# and the 22/22 characterization gate is byte-exact. Flip to true to opt in
# to the arena-raider-squad (4 experts) / arena-tribunal (3 jurors)
# roster. Cost is ~2-3x a single-agent cycle for those strategies.
MULTI_AGENT_ENABLED=false

# Strictness policy for sub-agent partial failure. True (default) = fail the
# cycle via MultiAgentDegradedError. False = soft-degrade and fall back to
# the single-agent path (ops escape hatch).
MULTI_AGENT_STRICT=true

# Per sub-agent (expert / juror) LLM timeout, wrapped with asyncio.wait_for.
EXPERT_TIMEOUT_SECONDS=15

# ── Observability ──────────────────────────────────────────────────────────
ENVIRONMENT=testnet
LOG_LEVEL=INFO
