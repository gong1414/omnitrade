# ============================================================================
# OmniTrade Backend — Environment Variables
# ============================================================================
# Copy this file to `.env` (at this path) for local dev, or to `.env` at
# the repo root for `docker compose up`. Both `.env` paths are git-ignored.
#
# Every key listed here is mapped to a `Settings` field in
# `src/omnitrade/config.py`. If you add a new field there, add the matching
# row here too — `apps/backend/.env.example` is the canonical reference.

# ── Server ─────────────────────────────────────────────────────────────────
PLATFORM_PORT=8000
ENVIRONMENT=testnet                   # `testnet` | `mainnet` — labels logs/traces
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# ── Trading ────────────────────────────────────────────────────────────────
# Strategy selection. The 11 named strategies live in domain/enums.py:
#   arena-guardian / arena-steward / arena-raider / arena-raider-squad /
#   arena-scalper / arena-swingsmith / arena-strider / arena-rebate-hunter /
#   arena-autopilot / arena-tribunal / arena-dual-signal
TRADING_STRATEGY=arena-autopilot
TRADING_INTERVAL_MINUTES=20
TRADING_SYMBOLS=["BTC_USDT","ETH_USDT"]

MAX_LEVERAGE=25
MAX_POSITIONS=5
MAX_HOLDING_HOURS=36
EXTREME_STOP_LOSS_PERCENT=-30
INITIAL_BALANCE_USDT=1000
ACCOUNT_STOP_LOSS_USDT=50
ACCOUNT_TAKE_PROFIT_USDT=20000
SYNC_CONFIG_ON_STARTUP=true

# Daily realized-PnL kill switch. Once today's PnL drops below
# -DAILY_LOSS_CAP_USDT, the next open/close/partial_close decision is
# rewritten to `hold` until UTC midnight.
DAILY_LOSS_CAP_USDT=100.0

# Drawdown rails (% of peak account equity)
ACCOUNT_DRAWDOWN_WARNING_PERCENT=20
ACCOUNT_DRAWDOWN_NO_NEW_POSITION_PERCENT=30
ACCOUNT_DRAWDOWN_FORCE_CLOSE_PERCENT=50

# Account-recorder cadence (minutes). The recorder also fires on every
# new account-equity peak via the 10-second monitor cycle.
ACCOUNT_RECORD_INTERVAL_MINUTES=1

# ── Database ───────────────────────────────────────────────────────────────
# Postgres + pgvector is the production path. SQLite still works for unit
# tests via aiosqlite (migration 0007 is a no-op on SQLite).
DATABASE_URL=postgresql+psycopg://omnitrade:omnitrade@postgres:5432/omnitrade
# DATABASE_URL=sqlite+aiosqlite:///./data/omnitrade.db   # dev fallback

# ── Exchange ───────────────────────────────────────────────────────────────
EXCHANGE=gate                          # `gate` | `okx`

# Gate.io
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret
GATE_USE_TESTNET=true                  # mainnet requires explicit flip

# OKX (used when EXCHANGE=okx)
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_API_PASSPHRASE=your_okx_passphrase
OKX_USE_TESTNET=true

# Manual close password (empty = disable UI close)
MANUAL_CLOSE_PASSWORD=

# ── LLM (via Agno's DeepSeek model class) ──────────────────────────────────
# Agno is the only framework after the cutover. LiteLLM has been removed.
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek/deepseek-v3.2-exp

# Agno's `DeepSeek(id=...)` model id. Common picks:
#   deepseek-v4-pro       (default — long-context reasoning)
#   deepseek-v4-flash     (cheaper, faster)
#   deepseek-reasoner     (slowest, deepest)
AGNO_LLM_MODEL=deepseek-reasoner

# Reject LLM responses without tool_calls. Set false for 1-release rollback only.
STRICT_TOOL_CALLS=true

# ── Embedder (T10 trade-journal RAG) ───────────────────────────────────────
# DeepSeek's API does NOT expose /v1/embeddings, so the default is a local,
# CPU-bound fastembed model. Switch to `openai` if you have an OpenAI key
# or an aggregator (OpenRouter etc) that proxies /embeddings.
EMBEDDER_PROVIDER=fastembed                    # `fastembed` | `openai`
EMBEDDER_MODEL_ID=BAAI/bge-small-en-v1.5       # 384-dim, ranks high on MTEB
EMBEDDER_API_KEY=                              # only when provider=openai
EMBEDDER_BASE_URL=                             # only when provider=openai

# fastembed pulls the model from huggingface.co on first run. The default
# TLS handshake is unreliable on cn networks — set HF_ENDPOINT to a mirror.
# These two are read by the `huggingface_hub` library directly (not by
# Settings), so they're plain process env vars.
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=/app/.cache/huggingface

# ── AgentOS native scheduler (Agno) ────────────────────────────────────────
# When true, AgentOS's cron drives the trading-cycle Workflow (15s poll)
# and APScheduler's `trading_cycle` job is suppressed. APScheduler still
# runs the 6 fast position-protection monitors at 10s cadence either way.
AGNO_SCHEDULER_DRIVES_CYCLE=true
AGNO_POSTGRES_URL=                             # falls back to DATABASE_URL
AGNO_SCHEDULER_BASE_URL=http://127.0.0.1:8000
AGNO_SCHEDULER_TOKEN=                          # bearer for the trigger callback
AGNO_SCHEDULER_POLL_INTERVAL=15

# ── Human-in-the-loop large-open gate (T9) ─────────────────────────────────
# Opens with USD notional > HITL_OPEN_SIZE_THRESHOLD_USD pause via SSE
# and require operator approval through the dashboard banner.
HITL_OPEN_SIZE_THRESHOLD_USD=10000.0
HITL_APPROVAL_WAIT_SECONDS=30.0

# ── Observability (T4 OpenTelemetry overlay) ───────────────────────────────
# Agno's setup_tracing + OpenInference's AgnoInstrumentor write spans to
# `ai.agno_spans`, exposed via AgentOS GET /traces.
OTEL_TRACING_ENABLED=true

# ── External data sources ──────────────────────────────────────────────────
# Free sources (no API key)
DATASOURCE_CRYPTO_NEWS_ENABLED=true
DATASOURCE_FEAR_GREED_ENABLED=true
DATASOURCE_COINGECKO_ENABLED=true
DATASOURCE_ONCHAIN_ENABLED=true
DATASOURCE_ORDER_BOOK_ENABLED=true
DATASOURCE_OPEN_INTEREST_ENABLED=true

# Keyed sources (auto-disabled when key empty)
DATASOURCE_COINGLASS_ENABLED=true
COINGLASS_API_KEY=                              # https://www.coinglass.com/pricing
DATASOURCE_WHALE_ALERT_ENABLED=true
WHALE_ALERT_API_KEY=                            # https://whale-alert.io/
ETHERSCAN_API_KEY=                              # https://etherscan.io/apis
DATASOURCE_LUNAR_CRUSH_ENABLED=true
LUNAR_CRUSH_API_KEY=                            # https://lunarcrush.com/developers

# ── MCP servers ────────────────────────────────────────────────────────────
GATE_NEWS_MCP_ENABLED=true
GATE_NEWS_MCP_URL=https://api.gatemcp.ai/mcp/news
TRADING_MCP_PORT=9090

# ── Rebate ─────────────────────────────────────────────────────────────────
FEE_REBATE_PERCENT=20

# ── Multi-agent orchestrator (Agno Team coordinate mode) ───────────────────
# Only `arena-tribunal` and `arena-raider-squad` are team-eligible. The
# other 9 strategies always run as a single Agno Agent.
MULTI_AGENT_ENABLED=true
MULTI_AGENT_STRICT=true
EXPERT_TIMEOUT_SECONDS=15

# ── Output ─────────────────────────────────────────────────────────────────
# Controls the language of the agent's structured reasoning (UI honours it).
OUTPUT_LANGUAGE=zh                             # `zh` | `en`
